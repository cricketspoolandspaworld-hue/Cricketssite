import React, { useState, useRef, useEffect } from 'react';
import { 
  Droplets, 
  Beaker, 
  ShieldCheck, 
  ArrowRight, 
  AlertTriangle, 
  RefreshCcw,
  Waves,
  Camera,
  Printer,
  Info
} from 'lucide-react';

const App = () => {
  const [activeStep, setActiveStep] = useState(0);
  const [isExporting, setIsExporting] = useState(false);
  const printRef = useRef(null);

  useEffect(() => {
    // Load html-to-image for the JPEG export functionality
    const script = document.createElement('script');
    script.src = "https://cdnjs.cloudflare.com/ajax/libs/html-to-image/1.11.11/html-to-image.min.js";
    script.async = true;
    document.head.appendChild(script);
    return () => document.head.removeChild(script);
  }, []);

  const exportAsImage = async () => {
    if (!printRef.current || isExporting) return;
    setIsExporting(true);
    // Brief delay to ensure UI state syncs
    setTimeout(async () => {
      try {
        const dataUrl = await window.htmlToImage.toJpeg(printRef.current, {
          quality: 0.95,
          backgroundColor: '#f8fafc',
        });
        const link = document.createElement('a');
        link.download = `Pool-Stain-Phase-${activeStep + 1}.jpg`;
        link.href = dataUrl;
        link.click();
      } catch (err) {
        console.error('Export failed', err);
      } finally {
        setIsExporting(false);
      }
    }, 150);
  };

  const handlePrint = () => {
    // Ensure the iframe/window has focus to trigger the print dialog reliably
    window.focus();
    window.print();
  };

  const steps = [
    {
      title: "Phase 1: Dilution & Source Control",
      icon: <RefreshCcw className="w-6 h-6" />,
      color: "bg-blue-600",
      summary: "Resetting the chemical baseline by removing high CYA and Copper loads.",
      details: [
        "Drain 60-70% of the pool water (consult professional for hydrostatic safety).",
        "Deactivate the Go Chemless BioSanitizer (set to 0% or turn off).",
        "Refill with fresh water to bring Cyanuric Acid (CYA) below 50 ppm.",
        "Add an initial dose of metal sequestering agent to protect new water."
      ],
      warning: "Do not drain if groundwater levels are high (common in Lafayette after heavy rain)."
    },
    {
      title: "Phase 2: LSI Stabilization",
      icon: <Waves className="w-6 h-6" />,
      color: "bg-emerald-600",
      summary: "Moving the needle from Corrosive (-0.58) to Balanced (+0.1).",
      details: [
        "Step A: Raise Total Alkalinity to 100-120 ppm using Sodium Bicarbonate.",
        "Step B: Raise Calcium Hardness to 350-400 ppm using Hardness Plus.",
        "Maintain pH at 7.2-7.4 to keep the LSI in the 'protective' zone.",
        "This prevents the water from 'eating' the plaster to satisfy its calcium demand."
      ],
      warning: "Always balance Alkalinity before Calcium to prevent cloudiness."
    },
    {
      title: "Phase 3: The Chemical 'Lift'",
      icon: <Beaker className="w-6 h-6" />,
      color: "bg-purple-600",
      summary: "Targeted removal of copper plating from the plaster surface.",
      details: [
        "Perform a Stain ID test with a Citric Acid kit to confirm metal lift.",
        "Drop Chlorine levels to 0-1 ppm (high chlorine neutralizes the lift).",
        "Apply Ascorbic Acid (Vitamin C) or Citric-based remover to stained areas.",
        "Allow to circulate for 24 hours while monitoring the 'fade'."
      ],
      warning: "Avoid 'shocking' the pool during this 24-48 hour window."
    },
    {
      title: "Phase 4: Lock-in & Prevention",
      icon: <ShieldCheck className="w-6 h-6" />,
      color: "bg-slate-800",
      summary: "Establishing a sustainable maintenance loop to prevent recurrence.",
      details: [
        "Add maintenance dose of sequesterant to keep lifted copper in solution.",
        "Switch from Chlor Brite (Dichlor) to Liquid Chlorine (Sodium Hypochlorite).",
        "Reactivate Go Chemless unit at a low output (target 0.15 ppm Copper).",
        "Test monthly for LSI compliance to ensure plaster longevity."
      ],
      warning: "Liquid chlorine won't raise your CYA, keeping your sanitizer effective."
    }
  ];

  return (
    <div className="min-h-screen bg-slate-50 p-4 md:p-8 font-sans">
      <style>{`
        @media print {
          .no-print { display: none !important; }
          .print-only { display: block !important; visibility: visible !important; }
          .page-break { page-break-after: always; }
          
          body, html { 
            background: white !important; 
            margin: 0 !important; 
            padding: 0 !important;
            height: auto !important;
            overflow: visible !important;
          }

          /* Reset container for full-width print */
          .max-w-5xl { 
            max-width: 100% !important; 
            width: 100% !important;
            margin: 0 !important;
            border: none !important;
            box-shadow: none !important;
          }

          .rounded-3xl { border-radius: 0 !important; }
          
          /* Force the grid to act as a single column for printing sequential phases */
          .grid { display: block !important; }
          
          .bg-slate-900 { background-color: #0f172a !important; -webkit-print-color-adjust: exact; }
          .bg-slate-100 { background-color: #f1f5f9 !important; -webkit-print-color-adjust: exact; }
        }
        .print-only { display: none; }
      `}</style>

      <div ref={printRef} className="max-w-5xl mx-auto bg-white rounded-3xl shadow-2xl overflow-hidden border border-slate-200">
        
        {/* Header Section */}
        <header className="bg-slate-900 text-white p-8 md:p-12 relative overflow-hidden">
          <div className="relative z-10">
            <div className="flex items-center gap-3 mb-4">
              <Droplets className="text-blue-400 w-8 h-8" />
              <span className="text-blue-400 font-bold tracking-widest text-sm uppercase">Technical Service Blueprint</span>
            </div>
            <h1 className="text-4xl md:text-5xl font-extrabold mb-4 tracking-tight">Charley's Stain Resolution Guide</h1>
            <p className="text-slate-400 text-lg max-w-2xl leading-relaxed">
              Addressing the metal precipitation caused by the interaction of the <span className="text-white font-semibold italic">Go Chemless</span> system and current corrosive water chemistry (-0.58 LSI).
            </p>
          </div>
        </header>

        {/* Status Bar */}
        <div className="bg-slate-100 border-y border-slate-200 grid grid-cols-2 md:grid-cols-4 divide-x divide-slate-200 text-center py-6">
          <div>
            <p className="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-1">Current CYA</p>
            <p className="text-2xl font-black text-red-600">88 <span className="text-sm font-normal">ppm</span></p>
          </div>
          <div>
            <p className="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-1">Current LSI</p>
            <p className="text-2xl font-black text-red-600">-0.58 <span className="text-sm font-normal text-slate-400">crit</span></p>
          </div>
          <div>
            <p className="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-1">Copper Load</p>
            <p className="text-2xl font-black text-amber-600">0.30 <span className="text-sm font-normal">ppm</span></p>
          </div>
          <div>
            <p className="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-1">Target LSI</p>
            <p className="text-2xl font-black text-emerald-600">+0.10 <span className="text-sm font-normal text-slate-400">safe</span></p>
          </div>
        </div>

        {/* Main Layout Body */}
        <div className="grid md:grid-cols-12 gap-0">
          
          {/* INTERACTIVE SIDEBAR (Hidden in Print) */}
          <div className={`md:col-span-4 bg-slate-50 border-r border-slate-200 no-print ${isExporting ? 'hidden' : 'block'}`}>
            <div className="p-4 bg-slate-100/50 border-b border-slate-200">
               <p className="text-[10px] font-black uppercase text-slate-400 tracking-tighter flex items-center gap-2">
                 <Info className="w-3 h-3" /> Select a Phase to View
               </p>
            </div>
            {steps.map((step, idx) => (
              <button
                key={idx}
                onClick={() => setActiveStep(idx)}
                className={`w-full text-left p-6 transition-all border-b border-slate-200 flex items-start gap-4 ${
                  activeStep === idx ? 'bg-white shadow-inner border-l-4 border-l-blue-600' : 'hover:bg-slate-100'
                }`}
              >
                <div className={`mt-1 p-2 rounded-lg ${activeStep === idx ? step.color + ' text-white shadow-md' : 'bg-slate-200 text-slate-500'}`}>
                  {step.icon}
                </div>
                <div>
                  <h3 className={`font-bold text-sm ${activeStep === idx ? 'text-slate-900' : 'text-slate-500'}`}>{step.title}</h3>
                </div>
              </button>
            ))}
          </div>

          {/* INTERACTIVE CONTENT (Hidden in Print) */}
          <div className={`${isExporting ? 'md:col-span-12' : 'md:col-span-8'} p-8 md:p-12 no-print`}>
            <div className="flex items-center gap-4 mb-8">
              <div className={`h-12 w-12 rounded-2xl flex items-center justify-center text-white ${steps[activeStep].color} shadow-lg`}>
                {steps[activeStep].icon}
              </div>
              <h2 className="text-3xl font-black text-slate-900 tracking-tight">{steps[activeStep].title}</h2>
            </div>
            <div className="space-y-6">
              <ul className="grid gap-4">
                {steps[activeStep].details.map((detail, dIdx) => (
                  <li key={dIdx} className="flex items-start gap-4 p-5 bg-slate-50 rounded-2xl border border-slate-100 shadow-sm">
                    <div className="h-6 w-6 rounded-full bg-white border border-slate-200 flex items-center justify-center text-[10px] font-bold text-slate-500 shrink-0 mt-0.5 shadow-sm">
                      {dIdx + 1}
                    </div>
                    <p className="text-slate-700 font-semibold leading-relaxed">{detail}</p>
                  </li>
                ))}
              </ul>
              <div className="p-6 bg-amber-50 border border-amber-200 rounded-2xl flex items-start gap-4 mt-8">
                <AlertTriangle className="text-amber-600 w-6 h-6 shrink-0 mt-1" />
                <div className="text-amber-900">
                  <p className="text-xs font-black uppercase tracking-widest mb-1">Field Alert</p>
                  <p className="text-sm font-medium leading-relaxed">{steps[activeStep].warning}</p>
                </div>
              </div>
            </div>
          </div>

          {/* PRINT-ONLY FULL LAYOUT (Visible in Print Only) */}
          <div className="print-only md:col-span-12 p-12">
            <h2 className="text-sm font-black uppercase tracking-[0.2em] text-slate-400 mb-10 border-b pb-4">Full Treatment Sequence</h2>
            {steps.map((step, idx) => (
              <div key={idx} className={`mb-16 ${idx < steps.length - 1 ? 'page-break border-b border-slate-100 pb-16' : ''}`}>
                <div className="flex items-center gap-4 mb-8">
                  <div className={`h-12 w-12 rounded-xl flex items-center justify-center text-white ${step.color}`}>
                    {step.icon}
                  </div>
                  <h3 className="text-3xl font-bold text-slate-900 tracking-tight">{step.title}</h3>
                </div>
                <div className="space-y-6 mb-8">
                  {step.details.map((detail, dIdx) => (
                    <div key={dIdx} className="flex items-start gap-4 text-slate-700 text-lg">
                      <span className="font-black text-slate-300 shrink-0 min-w-[24px]">{dIdx + 1}.</span>
                      <p>{detail}</p>
                    </div>
                  ))}
                </div>
                <div className="p-6 bg-slate-50 border border-slate-200 rounded-xl flex gap-4 text-slate-600 text-sm italic">
                  <AlertTriangle className="w-5 h-5 text-slate-400 shrink-0" />
                  <p><strong>Note:</strong> {step.warning}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        {/* Footer with Export Actions */}
        <footer className="bg-slate-900 text-white p-8 border-t border-white/10 no-print">
          <div className="flex flex-col md:flex-row justify-between items-center gap-8">
            <div className="flex items-center gap-4">
              <ShieldCheck className="w-10 h-10 text-emerald-400" />
              <div>
                <p className="font-bold text-white text-xs tracking-widest uppercase">Verified LSI Protocol</p>
                <p className="text-slate-400 text-sm">Follow sequence exactly to avoid further etching.</p>
              </div>
            </div>
            <div className="flex flex-wrap gap-4">
              <button 
                onClick={exportAsImage}
                disabled={isExporting}
                className="flex items-center gap-3 px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white rounded-xl text-xs font-bold transition-all shadow-lg shadow-blue-900/40"
              >
                {isExporting ? <RefreshCcw className="w-4 h-4 animate-spin" /> : <Camera className="w-4 h-4" />}
                JPEG Current Phase
              </button>
              <button 
                onClick={handlePrint}
                className="flex items-center gap-3 px-6 py-3 bg-slate-700 hover:bg-slate-600 text-white rounded-xl text-xs font-bold transition-all shadow-lg shadow-slate-900/40"
              >
                <Printer className="w-4 h-4" /> Save Full PDF
              </button>
            </div>
          </div>
        </footer>
      </div>
      
      <div className="max-w-5xl mx-auto mt-6 flex flex-col md:flex-row justify-between items-center px-4 gap-4 no-print">
        <p className="text-slate-400 text-[10px] font-bold uppercase tracking-widest text-center md:text-left">
          Lafayette, LA Technical Standards • Cricket's Pool & Spa World
        </p>
        <div className="flex gap-6">
           <button className="text-blue-500 hover:text-blue-600 text-xs font-bold underline decoration-2 underline-offset-4">Treatment Support</button>
           <button className="text-blue-500 hover:text-blue-600 text-xs font-bold underline decoration-2 underline-offset-4">Chemical Log Sync</button>
        </div>
      </div>
    </div>
  );
};

export default App;
